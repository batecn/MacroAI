  </defs>
  <rect width="600" height="400" fill="url(#bg)"/>
  <rect x="20" y="20" width="560" height="360" rx="12" fill="none" stroke="#2a2a3e" stroke-width="2"/>
  <circle cx="45" cy="45" r="6" fill="#ff5f57"/>
  <circle cx="65" cy="45" r="6" fill="#ffbd2e"/>
  <circle cx="85" cy="45" r="6" fill="#28c840"/>
